# Skein frontend env. Copy to .env.local to override.

# MOCK mode drives the whole UI from the in-browser mesh engine — no backend
# needed. This is the safe default when no WS url is set. Set to "true" to force
# mock even if a WS url is present.
NEXT_PUBLIC_MOCK=true

# LIVE mode: point at the Python backend WebSocket (Task B). When this is set
# and NEXT_PUBLIC_MOCK is not "true", the dashboard streams real ML-driven state.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
